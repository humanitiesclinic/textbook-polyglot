            <cell>Bilabial</cell>
            <cell>Labio-dental</cell>
            <cell>Alveolar</cell>
            <cell>Palato-alv.</cell>
            <cell>Velar</cell>
            <cell>Glottal</cell>
          </row>
          <row>
            <cell>Stops</cell>
            <cell>p b</cell>
            <cell></cell>
            <cell>t d</cell>
            <cell></cell>
            <cell>k g</cell>
